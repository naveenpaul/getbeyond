# getbeyond web — environment variables.
# Copy to .env.local (gitignored) for local dev.

# --- API base URL (no trailing slash) ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Dev seed identity ---
# Created by `pnpm --filter @getbeyond/api seed:dev` once the DB is up.
# Real auth replaces these in v1.1.
NEXT_PUBLIC_DEV_ORG_ID=
NEXT_PUBLIC_DEV_USER_ID=usr_dev

# --- Port (optional; default 3001) ---
WEB_PORT=3001
